# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://feedagg:feedagg_pass@db:5432/feed_aggregator
DATABASE_URL_SYNC=postgresql://feedagg:feedagg_pass@db:5432/feed_aggregator

# ── App ───────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-random-string-64-chars
APP_HOST=0.0.0.0
APP_PORT=8000
FEED_OUTPUT_DIR=/app/static/feed
FEED_BASE_URL=https://your-server.com/feed

# ── Feed cache ────────────────────────────────────────────────────────────────
# Raw feeds are saved here after each successful download.
# Used as fallback when a source is temporarily unavailable.
FEED_CACHE_DIR=/app/cache

# ── Scheduler ─────────────────────────────────────────────────────────────────
SYNC_INTERVAL_HOURS=4

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── Thresholds ────────────────────────────────────────────────────────────────
# Object count change > CRITICAL % → update rejected, old data kept
THRESHOLD_DROP_WARNING=20
THRESHOLD_DROP_CRITICAL=50
# % of objects with significant price change → WARNING alert
THRESHOLD_PRICE_CHANGE_PCT=15
# Min price change per object (%) to count toward the alert above
THRESHOLD_PRICE_CHANGE_MIN=10
# Consecutive source failures before CRITICAL alert
THRESHOLD_SOURCE_FAIL_COUNT=2

# ── Pre-flight diagnostics ────────────────────────────────────────────────────
# Timeout for pre-flight URL checks (seconds).  Keep this short.
PREFLIGHT_TIMEOUT_S=5

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Feed HTTP server ──────────────────────────────────────────────────────────
FEED_SERVE_PORT=8080
